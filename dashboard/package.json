{
  "name": "dash",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-dev-ports.mjs",
    "build": "pnpm exec turbo run build",
    "dev": "pnpm infra:up:core && pnpm exec turbo run dev worker:reserve-snapshot --filter=api --filter=./apps/webTest",
    "lint": "pnpm exec turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "pnpm exec turbo run check-types",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:preflight:dashboard-integrity": "pnpm --filter api preflight:dashboard-integrity",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:migrate:safe": "pnpm db:preflight:dashboard-integrity && pnpm db:migrate",
    "db:push": "pnpm --filter @repo/db db:push",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "infra:up": "pnpm infra:up:dev",
    "infra:up:dev": "docker compose -f docker-compose.dev.yml up -d",
    "infra:up:prod": "docker compose -f docker-compose.yml up -d",
    "infra:up:core": "docker compose -f docker-compose.dev.yml up -d postgres pgbouncer redis && (docker compose -f docker-compose.dev.yml stop redisinsight || true)",
    "infra:down": "pnpm infra:down:dev",
    "seed:rbac": "pnpm --filter api seed:rbac",
    "infra:down:dev": "docker compose -f docker-compose.dev.yml down",
    "infra:down:prod": "docker compose -f docker-compose.yml down",
    "infra:logs": "pnpm infra:logs:dev",
    "infra:logs:dev": "docker compose -f docker-compose.dev.yml logs -f",
    "infra:logs:prod": "docker compose -f docker-compose.yml logs -f"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tailwindcss": "4.2.1",
    "turbo": "^2.8.12",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
