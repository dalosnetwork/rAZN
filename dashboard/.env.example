# -------- Auth / API --------
# Database credentials used by postgres/pgbouncer/api
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard
POSTGRES_DB=dashboard
# Internal redis URL inside Docker network
REDIS_URL=redis://redis:6379

# Generate a long random secret in production
BETTER_AUTH_SECRET=9F5C1xgAqz7o8u0m2xv7X7YpH0rGQ0nQ4YwC8GmJ5eQ=
# Public hostname used by Caddy for automatic HTTPS certificate management
CADDY_HOST=razn.example.com

BETTER_AUTH_URL=https://razn.example.com
# Optional Google OAuth (enable social login)
# Redirect URI in Google Console: https://dashboard.razn.example.com/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CORS_ORIGIN=https://razn.example.com
NEXT_PUBLIC_API_BASE_URL=https://razn.example.com/api

# -------- Session config --------
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_SESSION_UPDATE_AGE_SECONDS=900
AUTH_SESSION_COOKIE_CACHE_MAX_AGE_SECONDS=300
PGBOUNCER_POOL_MAX=20

# -------- Rate limit (optional) --------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
# 1 = trust direct proxy (Caddy), 2+ = include additional trusted upstream proxies/LBs
RATE_LIMIT_TRUSTED_PROXY_HOPS=1

# -------- KYB upload protection --------
# Max uploads per user in a rolling window
KYB_UPLOAD_RATE_LIMIT_MAX_FILES=10
# Window duration in seconds (10 minutes)
KYB_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=600
# Max single file size in bytes (25 MB)
KYB_MAX_FILE_SIZE_BYTES=26214400

# -------- BSC on-chain execution --------
# BSC testnet RPC endpoint used for mint/redeem confirmations
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# Expected network for tx verification
BSC_CHAIN_ID=97
# Proxy token contract address used by dashboard mint/redeem ops
BSC_TOKEN_CONTRACT_ADDRESS=0xb11fc1e75b837e1719565271ba4ba5b6b2e794fe
# Redeem function options: burnFrom | burn | redeem
BSC_TOKEN_REDEEM_FUNCTION=burnFrom
# Wait policy before marking request as completed
BSC_TX_CONFIRMATIONS=1
BSC_TX_TIMEOUT_MS=120000
# -------- Web wallet tx settings --------
# Admin MetaMask sends transactions to this contract on this chain
NEXT_PUBLIC_BSC_CHAIN_ID=97
NEXT_PUBLIC_BSC_TOKEN_CONTRACT_ADDRESS=0xb11fc1e75b837e1719565271ba4ba5b6b2e794fe
# Redeem function options: burnFrom | burn | redeem
NEXT_PUBLIC_BSC_TOKEN_REDEEM_FUNCTION=burnFrom

# -------- Web -> API (optional overrides) --------
# Server-side API URL inside Docker network
API_BASE_URL=http://api:3002
# Only needed if client-side requests must go through public URL
# Dev: Leave unset (defaults to http://localhost:3002)
# Prod: https://your-domain/api (Caddy should reverse-proxy /api to api:3002)
# NEXT_PUBLIC_API_BASE_URL=https://your-domain/api
